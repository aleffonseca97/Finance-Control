generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  passwordHash            String
  name                    String?
  createdAt               DateTime  @default(now())
  hasSeenWelcome          Boolean   @default(false)
  marketingOptIn          Boolean   @default(false)
  passwordResetTokenHash  String?
  passwordResetExpires    DateTime?
  categories      Category[]
  transactions    Transaction[]
  investments     Investment[]
  goals           Goal[]
  creditCards     CreditCard[]
}

model Category {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  icon               String   @default("CircleDollarSign")
  type               String   // income | expense | investment
  investmentSubtype  String?  // reserva | carteira (only for type investment)
  isFixed            Boolean  @default(false) // only for expense
  defaultValue      Float?   // valor prefixado para despesas fixas
  color              String?  @default("#6366f1")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  investments        Investment[]      @relation("InvestmentCategory")
  reserveInvestments Investment[]      @relation("ReserveCategory")
  walletInvestments  Investment[]      @relation("WalletCategory")
  goalReserves       Goal[]            @relation("GoalReserveCategory")

  @@index([userId])
  @@index([userId, type])
}

model Transaction {
  id                       String     @id @default(cuid())
  userId                   String
  categoryId               String
  amount                   Float
  description              String?
  date                     DateTime
  type                     String     // income | expense
  creditCardId             String?    // compra no cartão — reduz limite disponível
  paysCreditCardId         String?    // pagamento em dinheiro — restaura limite disponível
  creditCarryoverCardId    String?    // fatura fechada (despesa variável após o fechamento)
  creditCarryoverPeriodEnd DateTime?  // data do fechamento do ciclo (chave idempotente)
  user                     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  category                 Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  creditCard               CreditCard? @relation("CardCharge", fields: [creditCardId], references: [id], onDelete: SetNull)
  paysCreditCard           CreditCard? @relation("CardPayment", fields: [paysCreditCardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, date])
  @@index([categoryId])
  @@index([creditCardId])
  @@index([paysCreditCardId])
  @@unique([userId, creditCarryoverCardId, creditCarryoverPeriodEnd], map: "Transaction_credit_carryover_key")
}

model Investment {
  id                String    @id @default(cuid())
  userId            String
  categoryId        String?   // legacy fallback
  reserveCategoryId String?
  walletCategoryId  String?
  amount            Float     // positive = aporte, negative = saque
  affectsCash       Boolean   @default(true)
  date              DateTime
  notes             String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category          Category? @relation("InvestmentCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  reserveCategory   Category? @relation("ReserveCategory", fields: [reserveCategoryId], references: [id], onDelete: SetNull)
  walletCategory    Category? @relation("WalletCategory", fields: [walletCategoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, date])
  @@index([categoryId])
  @@index([reserveCategoryId])
  @@index([walletCategoryId])
}

model CreditCard {
  id           String        @id @default(cuid())
  userId       String
  name         String
  lastFour     String?       // últimos 4 dígitos (ex: "1234")
  limit        Float         // limite disponível (só sobe após pagamento da fatura)
  totalLimit   Float         // limite total contratado
  closingDay   Int           // dia do fechamento (1-31)
  dueDay       Int           // dia do vencimento (1-31)
  color        String?       @default("#6366f1")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chargeTransactions  Transaction[] @relation("CardCharge")
  paymentTransactions Transaction[] @relation("CardPayment")

  @@index([userId])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  reserveCategoryId String?
  name         String
  targetAmount Float
  currentAmount Float   @default(0)
  deadline     DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reserveCategory Category? @relation("GoalReserveCategory", fields: [reserveCategoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deadline])
  @@index([reserveCategoryId])
}
